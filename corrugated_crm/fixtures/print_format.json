    "html": "{% set doc = frappe.get_doc(doc.doctype, doc.name) %}\n<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<style>\n  body { font-family: Arial, sans-serif; font-size: 11pt; color: #222; margin: 0; padding: 0; }\n  .spec-card { max-width: 720px; margin: 0 auto; padding: 24px; }\n  .header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 3px solid #2563EB; padding-bottom: 12px; margin-bottom: 20px; }\n  .header h1 { margin: 0; font-size: 20pt; color: #2563EB; }\n  .header .meta { text-align: right; font-size: 9pt; color: #666; }\n  .section { margin-bottom: 20px; }\n  .section-title { font-size: 11pt; font-weight: bold; color: #fff; background: #2563EB; padding: 4px 10px; border-radius: 3px; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }\n  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px 24px; }\n  .field { display: flex; flex-direction: column; }\n  .field label { font-size: 8pt; color: #888; text-transform: uppercase; letter-spacing: 0.5px; }\n  .field span { font-size: 11pt; font-weight: 600; color: #111; border-bottom: 1px solid #e5e7eb; padding-bottom: 2px; }\n  .dims-box { background: #f0f4ff; border: 2px solid #2563EB; border-radius: 6px; padding: 12px 20px; display: flex; gap: 28px; align-items: center; justify-content: center; margin: 8px 0; }\n  .dim { text-align: center; }\n  .dim .val { font-size: 18pt; font-weight: bold; color: #2563EB; }\n  .dim .lbl { font-size: 8pt; color: #555; text-transform: uppercase; }\n  .dim-x { font-size: 16pt; color: #aaa; margin-top: -4px; }\n  .notes { background: #fafafa; border: 1px solid #e5e7eb; border-radius: 4px; padding: 10px; font-size: 10pt; white-space: pre-wrap; min-height: 40px; }\n  .file-link { font-size: 10pt; color: #2563EB; word-break: break-all; }\n  .footer { margin-top: 24px; border-top: 1px solid #e5e7eb; padding-top: 8px; font-size: 8pt; color: #aaa; text-align: center; }\n  @media print { .spec-card { padding: 0; } }\n</style>\n</head>\n<body>\n<div class=\"spec-card\">\n\n  <div class=\"header\">\n    <div>\n      <h1>📦 Corrugated Spec Card</h1>\n      <div style=\"font-size:13pt;font-weight:600;margin-top:4px;\">{{ doc.deal_name or doc.name }}</div>\n      <div style=\"font-size:10pt;color:#666;\">{{ doc.customer or doc.organization }}</div>\n    </div>\n    <div class=\"meta\">\n      <div><b>Deal ID:</b> {{ doc.name }}</div>\n      <div><b>Status:</b> {{ doc.status }}</div>\n      <div><b>Sales Rep:</b> {{ doc.deal_owner }}</div>\n      <div><b>Date:</b> {{ frappe.utils.formatdate(frappe.utils.nowdate()) }}</div>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <div class=\"section-title\">Box Specification</div>\n    <div class=\"grid\">\n      <div class=\"field\"><label>Box Style</label><span>{{ doc.box_style or \"—\" }}</span></div>\n      <div class=\"field\"><label>Flute Type</label><span>{{ doc.flute_type or \"—\" }}</span></div>\n      <div class=\"field\"><label>Board Grade / ECT</label><span>{{ doc.board_grade or \"—\" }}</span></div>\n      <div class=\"field\"><label>Annual Quantity</label><span>{{ \"{:,}\".format(doc.annual_quantity) if doc.annual_quantity else \"—\" }}</span></div>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <div class=\"section-title\">Inside Dimensions</div>\n    <div class=\"dims-box\">\n      <div class=\"dim\"><div class=\"val\">{{ \"{:.3f}\".format(doc.box_length) if doc.box_length else \"—\" }}</div><div class=\"lbl\">Length (in)</div></div>\n      <div class=\"dim-x\">×</div>\n      <div class=\"dim\"><div class=\"val\">{{ \"{:.3f}\".format(doc.box_width) if doc.box_width else \"—\" }}</div><div class=\"lbl\">Width (in)</div></div>\n      <div class=\"dim-x\">×</div>\n      <div class=\"dim\"><div class=\"val\">{{ \"{:.3f}\".format(doc.box_depth) if doc.box_depth else \"—\" }}</div><div class=\"lbl\">Depth (in)</div></div>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <div class=\"section-title\">Print Specifications</div>\n    <div class=\"grid\">\n      <div class=\"field\"><label># Colors</label><span>{{ doc.num_colors or \"0 - Unprinted\" }}</span></div>\n      <div class=\"field\"><label>Print Method</label><span>{{ doc.print_method or \"—\" }}</span></div>\n      <div class=\"field\"><label>Coating</label><span>{{ doc.coating or \"None\" }}</span></div>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <div class=\"section-title\">CAD &amp; Artwork Files</div>\n    <div class=\"grid\">\n      <div class=\"field\">\n        <label>CAD File</label>\n        {% if doc.cad_file %}\n          <span class=\"file-link\">{{ doc.cad_file.split('/')[-1] }}</span>\n        {% else %}<span style=\"color:#aaa;\">No file attached</span>{% endif %}\n      </div>\n      <div class=\"field\">\n        <label>Print Artwork</label>\n        {% if doc.print_artwork %}\n          <span class=\"file-link\">{{ doc.print_artwork.split('/')[-1] }}</span>\n        {% else %}<span style=\"color:#aaa;\">No file attached</span>{% endif %}\n      </div>\n    </div>\n  </div>\n\n  {% if doc.spec_notes %}\n  <div class=\"section\">\n    <div class=\"section-title\">Spec Notes</div>\n    <div class=\"notes\">{{ doc.spec_notes }}</div>\n  </div>\n  {% endif %}\n\n  <div class=\"footer\">Generated by Welchwyse Corrugated CRM &bull; {{ frappe.utils.now() }}</div>\n</div>\n</body>\n</html>"
